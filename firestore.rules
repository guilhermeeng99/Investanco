rules_version = '2';

// Each user owns everything under users/{uid}. No cross-user access. Quotes and
// device settings stay local (not mirrored). See docs/specs/cloud_sync.md.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
