# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Drift web assets — downloaded at build time (CI) / for local web runs
/web/sqlite3.wasm
/web/drift_worker.dart.js

# Local commit-message scratch file
.commitmsg.tmp

# Local secrets (API tokens) — never commit. Use env.example.json as a template.
/env.json

# Android release signing — never commit (keystore + passwords). CI rebuilds
# these from repository secrets.
/android/key.properties
*.jks
